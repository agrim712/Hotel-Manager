generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Ensure this matches your .env file
}

model Property {
  id            String   @id @default(uuid())
  propertyName  String
  address       String
  city          String
  country       String
  yourName      String
  phoneCode     String
  phoneNumber   String
  whatsappNumber String?
  email         String   @unique
  propertyType  String
  totalRooms    Int
  products      String   // Stored as comma-separated values
  currency      String
  rooms         Room[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Room {
  id            String   @id @default(uuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomName      String
  numOfRooms    Int
  maxGuests     Int
  rateType      String
  rate          Float
  extraAdultRate Float?
  roomNumbers   String?  // Stored as comma-separated values
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}